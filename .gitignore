/target

# Advisory lock files created by kiro-market during concurrent operations
*.json.lock

# Python bytecode cache (tests under .github/scripts/)
__pycache__/
*.pyc

# Tethys index built by `cargo xtask plan-lint` (and direct `tethys index`).
# Never committed — recreated on demand from source. Scoped to `index/`
# only because `.rivets/` is also used by the rivets issue tracker (its
# `config.yaml` and `issues.jsonl` ARE tracked for collaboration).
/.rivets/index/

# Git worktrees for isolated feature branches
.worktrees/

# Brainstorming session mockups (persisted via --project-dir)
.superpowers/

# Per-machine Claude Code permission overrides (not shared across devs)
.claude/settings.local.json

# Per-project Kiro runtime state (which agents/steering files are installed
# locally). Tracked separately from the marketplace catalog; regenerated by
# the install commands.
.kiro/installed-agents.json
.kiro/installed-steering.json

# Stray local test artifacts (Windows builds occasionally drop these at the
# repo root; not part of the workspace target dir).
/test_*.exe
/test_*.pdb

# External design-system handoff (Figma export / similar). Kept locally for
# reference but not part of the workspace — duplicates real component
# filenames (BrowseTab.svelte etc.) and would clobber on `git add -A`.
/Kiro Control Center Design System/
