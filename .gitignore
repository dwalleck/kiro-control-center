/target

# Advisory lock files created by kiro-market during concurrent operations
*.json.lock

# Python bytecode cache (tests under .github/scripts/)
__pycache__/
*.pyc

# Tethys index built by `cargo xtask plan-lint` (and direct `tethys index`).
# Never committed — recreated on demand from source.
/.rivets/

# Git worktrees for isolated feature branches
.worktrees/

# Brainstorming session mockups (persisted via --project-dir)
.superpowers/

# Per-machine Claude Code permission overrides (not shared across devs)
.claude/settings.local.json

# Per-project Kiro runtime state (which agents/steering files are installed
# locally). Tracked separately from the marketplace catalog; regenerated by
# the install commands.
.kiro/installed-agents.json
.kiro/installed-steering.json
