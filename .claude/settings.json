{
  "autoMode": {
    "environment": [
      "$defaults",
      "Source control: github.com/dwalleck and all projects in it",
      "Local temp directories"
    ],
    "allow": [
      "$defaults",
      "Creation and deletion of temporary files and directories",
      "commits and pushes to allow repositories"
    ],
    "soft_deny": [
      "$defaults"
    ],
    "hard_deny": [
      "$defaults",
      "Deleting files, repositories"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && cargo xtask hook-block-cargo-lock",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && cargo xtask hook-post-edit",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
